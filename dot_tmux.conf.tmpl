# set scroll history to 100,000 lines
set-option -g history-limit 100000

# modern colors
set -g default-terminal "tmux-256color"
{{- if eq .chezmoi.os "darwin" }}
set -as terminal-features ",xterm-256color:RGB"
{{- else }}
set -ga terminal-overrides ",alacritty:Tc"
{{- end }}

# Avoid ESC delay
set -s escape-time 0

# Fix titlebar
set -g set-titles on
set -g set-titles-string "#T"

# VIM mode
set -g mode-keys vi
{{- if eq .chezmoi.os "darwin" }}
set -g status-keys vi
{{- end }}

# copy mode bindings
bind -T copy-mode-vi v send -X begin-selection
{{- if eq .chezmoi.os "darwin" }}
bind -T copy-mode-vi y send -X copy-pipe-and-cancel "reattach-to-user-namespace pbcopy"
unbind -T copy-mode-vi Enter
bind -T copy-mode-vi Enter send -X copy-pipe-and-cancel "reattach-to-user-namespace pbcopy"
{{- else }}
bind -T copy-mode-vi y send-keys -X copy-pipe 'xclip -in -selection clipboard &> /dev/null'
bind -T copy-mode-vi Enter send-keys -X cancel

# shortcut for moving tmux buffer to clipboard
# useful if you've selected with the mouse
bind-key -nr C-y run "tmux show-buffer | xclip -in -selection clipboard &> /dev/null"
{{- end }}

# Mouse friendly
set -g mouse on

# Move between panes with vi keys
bind h select-pane -L
bind j select-pane -D
bind k select-pane -U
bind l select-pane -R

{{- if eq .chezmoi.os "darwin" }}
# start indexing with 1
set -g base-index 1
set -g pane-base-index 1

set -g focus-events on
{{- end }}

######################
### DESIGN CHANGES ###
######################

# Avoid date/time taking up space
set -g status-right ''
set -g status-right-length 0

{{- if eq .chezmoi.os "darwin" }}
set -g @catppuccin_flavor "mocha"
set -g @catppuccin_window_status_style "rounded"

set -g status-right-length 200
set -g status-left-length 100
set -g status-left ""

set -g @plugin 'catppuccin/tmux#v2.1.2'
set -g @plugin 'tmux-plugins/tmux-cpu'
set -g @plugin 'tmux-plugins/tpm'

# Load catppuccin before configuring status-right so @catppuccin_status_* variables exist,
# and use -F on status-right so #{cpu_percentage} ends up literally in the option value
# for tmux-cpu (loaded via tpm below) to substitute.
run '~/.tmux/plugins/tmux/catppuccin.tmux'
set -gF status-right "#{E:@catppuccin_status_application}"
set -agF status-right "#{E:@catppuccin_status_cpu}"
set -agF status-right "#{E:@catppuccin_status_session}"

run '~/.tmux/plugins/tpm/tpm'
{{- else }}
source-file ~/.config/tmux/base16-gruvbox-dark-hard.conf
{{- end }}
